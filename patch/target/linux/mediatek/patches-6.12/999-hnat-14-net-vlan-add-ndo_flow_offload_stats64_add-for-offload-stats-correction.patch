From ec0c8c981ba46c49577a171af4a864675d8cf319 Mon Sep 17 00:00:00 2001
From: "chak-kei.lam" <chak-kei.lam@mediatek.com>
Date: Thu, 2 Apr 2026 14:15:41 +0800
Subject: [PATCH] net: vlan: add ndo_flow_offload_stats64_add for
 offload stats correction

Implement the ndo_flow_offload_stats64_add callback for VLAN virtual
devices to correct per-CPU software statistics when flows are
hardware-offloaded.

When a flow is offloaded to hardware, packets bypass the CPU and the
VLAN device's per-CPU statistics (vlan_pcpu_stats) become inaccurate.
The new vlan_dev_flow_offload_stats64_add() function compensates by
atomically adding the hardware-reported rx/tx packet and byte counts
into the per-CPU vlan_pcpu_stats via u64_stats_add(), ensuring that
vlan_dev_get_stats64() returns an accurate total inclusive of offloaded
traffic.
---
 net/8021q/vlan_dev.c | 21 +++++++++++++++++++++
 1 file changed, 21 insertions(+)

--- a/net/8021q/vlan_dev.c
+++ b/net/8021q/vlan_dev.c
@@ -704,6 +704,26 @@ static void vlan_dev_get_stats64(struct
 	stats->tx_dropped = tx_dropped;
 }
 
+static int vlan_dev_flow_offload_stats64_add(struct net_device *dev,
+					     const struct rtnl_link_stats64 *stats64)
+{
+	struct vlan_dev_priv *vlan = vlan_dev_priv(dev);
+	struct vlan_pcpu_stats *vstats;
+
+	if (!vlan->vlan_pcpu_stats)
+		return -EINVAL;
+
+	vstats = this_cpu_ptr(vlan->vlan_pcpu_stats);
+	u64_stats_update_begin(&vstats->syncp);
+	u64_stats_add(&vstats->rx_packets, stats64->rx_packets);
+	u64_stats_add(&vstats->rx_bytes, stats64->rx_bytes);
+	u64_stats_add(&vstats->tx_packets, stats64->tx_packets);
+	u64_stats_add(&vstats->tx_bytes, stats64->tx_bytes);
+	u64_stats_update_end(&vstats->syncp);
+
+	return 0;
+}
+
 #ifdef CONFIG_NET_POLL_CONTROLLER
 static void vlan_dev_poll_controller(struct net_device *dev)
 {
@@ -1073,6 +1093,7 @@ static const struct net_device_ops vlan_
 #if IS_ENABLED(CONFIG_NF_FLOW_TABLE)
 	.ndo_flow_offload_check = vlan_dev_flow_offload_check,
 #endif
+	.ndo_flow_offload_stats64_add = vlan_dev_flow_offload_stats64_add,
 	.ndo_hwtstamp_get	= vlan_hwtstamp_get,
 	.ndo_hwtstamp_set	= vlan_hwtstamp_set,
 };
