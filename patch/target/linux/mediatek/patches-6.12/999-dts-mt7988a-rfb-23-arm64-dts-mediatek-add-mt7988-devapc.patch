---
[v1] arm64: dts: mediatek: Add MT7988 device APC

Add devie APC for MT7988 to handle the situation when a transaction
violates the access permission control (APC) configured by system.
---
v1: Add MT7988 device APC
---

--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
@@ -1417,6 +1417,12 @@
 			status = "okay";
 			eth = <&eth>;
 		};
+
+		devapc: devapc@1a110000 {
+			compatible = "mediatek,mt7988-devapc";
+			reg = <0 0x1a110000 0 0x1000>;
+			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
