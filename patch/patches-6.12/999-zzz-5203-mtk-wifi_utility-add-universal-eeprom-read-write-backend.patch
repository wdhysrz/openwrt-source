--- /dev/null
+++ b/drivers/net/wireless/wifi_utility/mt_wifi_of.c
@@ -0,0 +1,331 @@
+#include <linux/err.h>
+#include <linux/kernel.h>
+#include <linux/nvmem-consumer.h>
+#include <linux/of.h>
+#include <linux/slab.h>
+#include <linux/types.h>
+#include <linux/unaligned.h>
+#include "mt_wifi_eeprom.h"
+
+static bool __mt_of_has_eeprom(struct device_node *np)
+{
+	if (of_find_property(np, "mediatek,eeprom-data", NULL))
+		return true;
+	if (of_find_property(np, "mediatek,mtd-eeprom", NULL))
+		return true;
+
+	return of_property_match_string(np, "nvmem-cell-names", "eeprom") >= 0;
+}
+
+static bool __mt_of_is_wifi_node(struct device_node *np)
+{
+	return of_device_is_compatible(np, "mediatek,wbsys") ||
+	       of_device_is_compatible(np, "mediatek,mt76") ||
+	       of_device_is_compatible(np, "mediatek,mt7981-wmac") ||
+	       of_device_is_compatible(np, "mediatek,mt7986-wmac");
+}
+
+static loff_t __mt_of_normalize_offset(loff_t from, loff_t base)
+{
+	if (base >= 0 && from >= base)
+		return from - base;
+
+	return from;
+}
+
+static int __mt_of_copy_eeprom(const void *data, size_t size, loff_t from,
+			       loff_t base, size_t len, u_char *buf)
+{
+	size_t copy;
+
+	if (from < 0)
+		return -EINVAL;
+	if (!len)
+		return 0;
+
+	memset(buf, 0, len);
+
+	from = __mt_of_normalize_offset(from, base);
+	if (from < 0 || from >= (loff_t)size)
+		return 0;
+
+	copy = min_t(size_t, len, size - (size_t)from);
+	memcpy(buf, (const u8 *)data + (size_t)from, copy);
+
+	return 0;
+}
+
+static int __mt_of_copy_cell(const void *data, size_t size, loff_t from,
+			     loff_t base, size_t len, u_char *buf,
+			     size_t *copied)
+{
+	u64 req, req_end, cell, cell_end, start, end;
+	size_t copy;
+
+	*copied = 0;
+
+	if (from < 0)
+		return -EINVAL;
+	if (!len || !size)
+		return 0;
+	if (base < 0)
+		base = 0;
+
+	req = from;
+	cell = base;
+	req_end = req + len;
+	cell_end = cell + size;
+	if (req_end < req || cell_end < cell)
+		return -EINVAL;
+
+	if (req_end <= cell || cell_end <= req)
+		return 0;
+
+	start = max(req, cell);
+	end = min(req_end, cell_end);
+	copy = (size_t)(end - start);
+
+	memcpy(buf + (size_t)(start - req),
+	       (const u8 *)data + (size_t)(start - cell), copy);
+	*copied = copy;
+
+	return 0;
+}
+
+static int __mt_of_get_mtd_eeprom(struct device_node *np,
+				  struct device_node **mtd_np,
+				  const char **part, loff_t *mtd_ofs)
+{
+	const __be32 *list;
+	phandle phandle;
+	int size;
+
+	list = of_get_property(np, "mediatek,mtd-eeprom", &size);
+	if (!list)
+		return -ENOENT;
+	if (size < 2 * sizeof(*list))
+		return -EINVAL;
+
+	phandle = be32_to_cpup(list++);
+	if (!phandle)
+		return -ENOENT;
+
+	*mtd_np = of_find_node_by_phandle(phandle);
+	if (!*mtd_np)
+		return -EINVAL;
+
+	*part = of_get_property(*mtd_np, "label", NULL);
+	if (!*part)
+		*part = (*mtd_np)->name;
+
+	*mtd_ofs = be32_to_cpup(list);
+
+	return 0;
+}
+
+static int __mt_of_get_mtd_base(struct device_node *np, loff_t *mtd_ofs)
+{
+	struct device_node *mtd_np;
+	const char *part;
+	int ret;
+
+	ret = __mt_of_get_mtd_eeprom(np, &mtd_np, &part, mtd_ofs);
+	if (ret)
+		return ret;
+
+	of_node_put(mtd_np);
+
+	return 0;
+}
+
+static int __mt_of_read_eeprom_data(struct device_node *np, loff_t from,
+				    size_t len, u_char *buf)
+{
+	loff_t base = -1;
+	const void *data;
+	int size;
+
+	data = of_get_property(np, "mediatek,eeprom-data", &size);
+	if (!data)
+		return -ENOENT;
+
+	__mt_of_get_mtd_base(np, &base);
+
+	return __mt_of_copy_eeprom(data, size, from, base, len, buf);
+}
+
+static int __mt_of_read_mtd_eeprom(struct device_node *np, loff_t from,
+				   size_t len, u_char *buf)
+{
+	struct device_node *mtd_np;
+	const char *part;
+	loff_t mtd_ofs;
+	int ret;
+
+	ret = __mt_of_get_mtd_eeprom(np, &mtd_np, &part, &mtd_ofs);
+	if (ret)
+		return ret;
+
+	if (from < 0) {
+		ret = -EINVAL;
+		goto out_put_node;
+	}
+	if (from < mtd_ofs)
+		from += mtd_ofs;
+
+	ret = mt_mtd_read_nm_wifi((char *)part, from, len, buf);
+	if (ret)
+		goto out_put_node;
+
+	if (of_property_read_bool(np, "big-endian")) {
+		u8 *data = buf;
+		int i;
+
+		for (i = 0; i < round_down(len, 2); i += 2)
+			put_unaligned_le16(get_unaligned_be16(&data[i]), &data[i]);
+	}
+
+out_put_node:
+	of_node_put(mtd_np);
+
+	return ret;
+}
+
+static int __mt_of_get_cell_base(struct device_node *np, const char *name,
+				 loff_t *base)
+{
+	struct device_node *cell_np;
+	const __be32 *reg;
+	int na;
+	int len;
+	int idx;
+	int ret = 0;
+
+	idx = of_property_match_string(np, "nvmem-cell-names", name);
+	if (idx < 0)
+		return idx;
+
+	cell_np = of_parse_phandle(np, "nvmem-cells", idx);
+	if (!cell_np)
+		return -ENOENT;
+
+	reg = of_get_property(cell_np, "reg", &len);
+	if (!reg) {
+		ret = -ENOENT;
+		goto out_put_node;
+	}
+
+	na = of_n_addr_cells(cell_np);
+	if (na <= 0)
+		na = 1;
+	if (len < na * sizeof(*reg)) {
+		ret = -EINVAL;
+		goto out_put_node;
+	}
+
+	*base = of_read_number(reg, na);
+
+out_put_node:
+	of_node_put(cell_np);
+
+	return ret;
+}
+
+static int __mt_of_read_nvmem_cell(struct device_node *np, const char *name,
+				   loff_t from, size_t len, u_char *buf,
+				   loff_t dflt_base)
+{
+	struct nvmem_cell *cell;
+	loff_t base = dflt_base;
+	const void *data;
+	size_t copied;
+	size_t size;
+	int ret;
+
+	cell = of_nvmem_cell_get(np, name);
+	if (IS_ERR(cell))
+		return PTR_ERR(cell);
+
+	data = nvmem_cell_read(cell, &size);
+	nvmem_cell_put(cell);
+	if (IS_ERR(data))
+		return PTR_ERR(data);
+
+	ret = __mt_of_get_cell_base(np, name, &base);
+	if (ret && dflt_base < 0)
+		goto out_free;
+
+	ret = __mt_of_copy_cell(data, size, from, base, len, buf, &copied);
+	if (!ret)
+		pr_info("%pOF: read nvmem cell %s base=0x%llx size=0x%zx "
+			"from=0x%llx len=0x%zx copied=0x%zx\n",
+			np, name, (unsigned long long)base, size,
+			(unsigned long long)from, len, copied);
+
+out_free:
+	kfree(data);
+
+	return ret;
+}
+
+static int __mt_of_read_nvmem_eeprom(struct device_node *np, loff_t from,
+				     size_t len, u_char *buf)
+{
+	int ret;
+
+	if (!len)
+		return 0;
+
+	memset(buf, 0, len);
+
+	ret = __mt_of_read_nvmem_cell(np, "eeprom", from, len, buf, 0);
+	if (ret)
+		return ret;
+
+	if (of_property_match_string(np, "nvmem-cell-names", "precal") >= 0) {
+		ret = __mt_of_read_nvmem_cell(np, "precal", from, len, buf, -1);
+		if (ret)
+			pr_info("%pOF: failed to read nvmem cell precal ret=%d\n",
+				np, ret);
+	}
+
+	return 0;
+}
+
+static int __mt_of_read_node_eeprom(struct device_node *np, loff_t from,
+				    size_t len, u_char *buf)
+{
+	if (of_find_property(np, "mediatek,eeprom-data", NULL))
+		return __mt_of_read_eeprom_data(np, from, len, buf);
+
+	if (of_find_property(np, "mediatek,mtd-eeprom", NULL))
+		return __mt_of_read_mtd_eeprom(np, from, len, buf);
+
+	if (of_property_match_string(np, "nvmem-cell-names", "eeprom") >= 0)
+		return __mt_of_read_nvmem_eeprom(np, from, len, buf);
+
+	return -ENOENT;
+}
+
+int mt_of_read_eeprom_wifi(loff_t from, size_t len, u_char *buf)
+{
+	struct device_node *np;
+	int ret;
+
+	if (!buf && len)
+		return -EINVAL;
+
+	for_each_of_allnodes(np) {
+		if (!of_device_is_available(np))
+			continue;
+		if (!__mt_of_is_wifi_node(np))
+			continue;
+		if (!__mt_of_has_eeprom(np))
+			continue;
+
+		ret = __mt_of_read_node_eeprom(np, from, len, buf);
+		return ret;
+	}
+
+	return -ENOENT;
+}
