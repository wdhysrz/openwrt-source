From e3c9c9b3f798c9d3910084b763607d17b0d54bb1 Mon Sep 17 00:00:00 2001
From: chasey-dev <ellenyoung0912@gmail.com>
Date: Tue, 28 Apr 2026 21:19:32 +0800
Subject: [PATCH] mediatek: wifi_utility: add universal EEPROM read/write backend
Legacy wifi_utility cannot handle various types of EEPROM. So we:
 - add OF read backend, support NVMEM API that works across partition or flash layouts.
 - refactor raw MTD read, enhance with error handling and lower case "factory" fallback.

With this patch, wifi_utility supports read priority below:
 `mediatek,eeprom-data` -> `mediatek,mtd-eeprom` -> nvmem-cells -> raw MTD "F/factory"

Signed-off-by: chasey-dev <ellenyoung0912@gmail.com>
---
 .../net/wireless/wifi_utility/Makefile        |   2 +
 .../wireless/wifi_utility/mt_wifi_eeprom.c    |  73 ++++
 .../wireless/wifi_utility/mt_wifi_eeprom.h    |  14 +
 .../net/wireless/wifi_utility/mt_wifi_mtd.c   |  81 +++--
 .../net/wireless/wifi_utility/mt_wifi_of.c    | 331 ++++++++++++++++++
 5 files changed, 465 insertions(+), 36 deletions(-)
 create mode 100644 drivers/net/wireless/wifi_utility/mt_wifi_eeprom.c
 create mode 100644 drivers/net/wireless/wifi_utility/mt_wifi_eeprom.h
 create mode 100644 drivers/net/wireless/wifi_utility/mt_wifi_of.c

--- a/drivers/net/wireless/wifi_utility/Makefile
+++ b/drivers/net/wireless/wifi_utility/Makefile
@@ -1,4 +1,6 @@
 #always build-in
 obj-y += mt_wifi_mtd.o
+obj-y += mt_wifi_of.o
+obj-y += mt_wifi_eeprom.o
 obj-y += pci_mediatek_rbus.o
 
--- /dev/null
+++ b/drivers/net/wireless/wifi_utility/mt_wifi_eeprom.c
@@ -0,0 +1,73 @@
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/types.h>
+#include "mt_wifi_eeprom.h"
+
+int mt_eeprom_read_wifi(loff_t from, size_t len, u_char *buf)
+{
+	int ret;
+
+	if (!buf && len)
+		return -EINVAL;
+
+	ret = mt_of_read_eeprom_wifi(from, len, buf);
+	if (!ret)
+		return 0;
+
+	pr_warn("%s: read eeprom from OF failed from=0x%llx len=0x%zx ret=%d\n",
+		__func__, (unsigned long long)from, len, ret);
+
+	ret = mt_mtd_read_nm_wifi("Factory", from, len, buf);
+	if (!ret) {
+		pr_info("%s: read MTD Factory from=0x%llx len=0x%zx\n",
+			__func__, (unsigned long long)from, len);
+		return 0;
+	}
+
+	pr_warn("%s: read MTD Factory failed from=0x%llx len=0x%zx ret=%d\n",
+		__func__, (unsigned long long)from, len, ret);
+
+	ret = mt_mtd_read_nm_wifi("factory", from, len, buf);
+	if (!ret) {
+		pr_info("%s: read MTD factory from=0x%llx len=0x%zx\n",
+			__func__, (unsigned long long)from, len);
+		return 0;
+	}
+
+	pr_err("%s: failed from=0x%llx len=0x%zx",
+	       __func__, (unsigned long long)from, len);
+
+	return ret;
+}
+EXPORT_SYMBOL(mt_eeprom_read_wifi);
+
+int mt_eeprom_write_wifi(loff_t to, size_t len, const u_char *buf)
+{
+	int ret;
+
+	if (!buf && len)
+		return -EINVAL;
+
+	ret = mt_mtd_write_nm_wifi("Factory", to, len, buf);
+	if (!ret) {
+		pr_info("%s: wrote MTD Factory to=%lld len=%zu\n",
+			__func__, (long long)to, len);
+		return 0;
+	}
+
+	pr_warn("%s: write MTD Factory failed to=%lld len=%zu ret=%d\n",
+		__func__, (long long)to, len, ret);
+
+	ret = mt_mtd_write_nm_wifi("factory", to, len, buf);
+	if (!ret) {
+		pr_info("%s: wrote MTD factory to=%lld len=%zu\n",
+			__func__, (long long)to, len);
+		return 0;
+	}
+
+	pr_err("%s: failed to=%lld len=%zu",
+	       __func__, (long long)to, len);
+
+	return ret;
+}
+EXPORT_SYMBOL(mt_eeprom_write_wifi);
--- /dev/null
+++ b/drivers/net/wireless/wifi_utility/mt_wifi_eeprom.h
@@ -0,0 +1,14 @@
