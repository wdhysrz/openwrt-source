+	MTK_ETHTOOL_STAT(tx_broadcast_bytes),
+	MTK_ETHTOOL_STAT(tx_broadcast_packets),
+	MTK_ETHTOOL_STAT(rx_unicast_bytes),
+	MTK_ETHTOOL_STAT(rx_unicast_packets),
+	MTK_ETHTOOL_STAT(rx_multicast_bytes),
+	MTK_ETHTOOL_STAT(rx_multicast_packets),
+	MTK_ETHTOOL_STAT(rx_broadcast_bytes),
+	MTK_ETHTOOL_STAT(rx_broadcast_packets),
