+static void mtk_stats_update_gmac_ext(struct mtk_mac *mac)
+{
+	struct mtk_hw_stats *hw_stats = mac->hw_stats;
+
+	hw_stats->rx_unicast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x00);
+	hw_stats->rx_unicast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x08);
+	hw_stats->rx_multicast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x10);
+	hw_stats->rx_multicast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x18);
+	hw_stats->rx_broadcast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x20);
+	hw_stats->rx_broadcast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x28);
+
+	hw_stats->tx_unicast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x30);
+	hw_stats->tx_unicast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x38);
+	hw_stats->tx_multicast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x40);
+	hw_stats->tx_multicast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x48);
+	hw_stats->tx_broadcast_packets +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x50);
+	hw_stats->tx_broadcast_bytes +=
+		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x58);
+}
+
+static void mtk_stats_update_xgmac(struct mtk_mac *mac)
+{
+	struct mtk_hw_stats *hw_stats = mac->hw_stats;
+	u64 rx_crcerr_cnt, rx_eof_cnt;
+
+	rx_crcerr_cnt = FIELD_GET(GENMASK(15, 0),
+				  mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x198));
+	rx_eof_cnt = FIELD_GET(GENMASK(15, 0),
+			       mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1a4));
+	if (rx_crcerr_cnt <= rx_eof_cnt * 2) {
+		hw_stats->rx_packets +=
+			mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x18c);
+		hw_stats->rx_bytes +=
+			mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1ac);
+		hw_stats->rx_flow_control_packets += FIELD_GET(GENMASK(15, 0),
+			mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x190));
+		hw_stats->rx_fcs_errors += rx_crcerr_cnt;
+		hw_stats->rx_long_errors += FIELD_GET(GENMASK(15, 0),
+			mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x194));
+		if (mac->hw->soc->caps != MT7988_CAPS)
+			hw_stats->rx_short_errors +=
+				mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1bc);
+		hw_stats->rx_unicast_packets +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1c0);
+		hw_stats->rx_unicast_bytes +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1c8);
+		hw_stats->rx_multicast_packets +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1d0);
+		hw_stats->rx_multicast_bytes +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1d8);
+		hw_stats->rx_broadcast_packets +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1e0);
+		hw_stats->rx_broadcast_bytes +=
+			mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x1e8);
+	}
+
+	hw_stats->tx_packets +=
+		mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x114);
+	hw_stats->tx_bytes +=
+		mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id) + 0x134);
+	hw_stats->tx_unicast_packets +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x150);
+	hw_stats->tx_unicast_bytes +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x158);
+	hw_stats->tx_multicast_packets +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x160);
+	hw_stats->tx_multicast_bytes +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x168);
+	hw_stats->tx_broadcast_packets +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x170);
+	hw_stats->tx_broadcast_bytes +=
+		mtk_r64(mac->hw, MTK_XMAC_MCR(mac->id) + 0x178);
+
+	mtk_m32(mac->hw, XMAC_GLB_CNTCLR, 0x1, MTK_XMAC_CNT_CTRL(mac->id));
+}
+
+static void mtk_stats_update_gdm(struct mtk_mac *mac)
+{
+	const struct mtk_reg_map *reg_map = mac->hw->soc->reg_map;
+	struct mtk_hw_stats *hw_stats = mac->hw_stats;
+	unsigned int offs = hw_stats->reg_offset;
+	u64 stats;
+
+	hw_stats->rx_bytes += mtk_r32(mac->hw, reg_map->gdm1_cnt + offs);
+	stats = mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x4 + offs);
+	if (stats)
+		hw_stats->rx_bytes += (stats << 32);
+	hw_stats->rx_packets +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x8 + offs);
+	hw_stats->rx_overflow +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x10 + offs);
+	hw_stats->rx_fcs_errors +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x14 + offs);
+	hw_stats->rx_short_errors +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x18 + offs);
+	hw_stats->rx_long_errors +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x1c + offs);
+	hw_stats->rx_checksum_errors +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x20 + offs);
+	hw_stats->rx_flow_control_packets +=
+		mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x24 + offs);
+
+	if (mtk_is_netsys_v3_or_greater(mac->hw)) {
+		hw_stats->tx_skip +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x50 + offs);
+		hw_stats->tx_collisions +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x54 + offs);
+		hw_stats->tx_bytes +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x40 + offs);
+		stats =  mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x44 + offs);
+		if (stats)
+			hw_stats->tx_bytes += (stats << 32);
+		hw_stats->tx_packets +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x48 + offs);
+	} else {
+		hw_stats->tx_skip +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x28 + offs);
+		hw_stats->tx_collisions +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x2c + offs);
+		hw_stats->tx_bytes +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x30 + offs);
+		stats =  mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x34 + offs);
+		if (stats)
+			hw_stats->tx_bytes += (stats << 32);
+		hw_stats->tx_packets +=
+			mtk_r32(mac->hw, reg_map->gdm1_cnt + 0x38 + offs);
+	}
+}
